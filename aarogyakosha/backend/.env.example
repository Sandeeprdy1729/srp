# Environment Configuration
# Copy to .env and customize

# Application
APP_NAME=AarogyaKosha
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aarogyakosha

# Redis Cache
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-this-to-a-secure-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aarogyakosha
MINIO_SECURE=false

# HAPI FHIR Server (Open Source FHIR Server)
HAPI_FHIR_URL=http://localhost:8080/fhir

# Meilisearch (Open Source Search)
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=masterKey

# NLP Model (BioBERT - Free from HuggingFace)
NLP_MODEL_NAME=dmis-lab/biobert-base-cased-v1.2
NLP_MODEL_CACHE=/tmp/nlp_models

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# File Upload
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=/tmp/aarogyakosha/uploads

# Logging
LOG_LEVEL=INFO

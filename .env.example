# AarogyaKosha - Environment Variables Template
# Copy to .env files and update for your environment

# ─── BACKEND ──────────────────────────────────────────
# aarogyakosha/backend/.env

APP_NAME=AarogyaKosha
APP_VERSION=1.0.0
DEBUG=False
HOST=0.0.0.0
PORT=8000

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aarogyakosha
REDIS_URL=redis://localhost:6379/0

SECRET_KEY=your-super-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aarogyakosha
MINIO_SECURE=False

CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com

MAX_FILE_SIZE_MB=50
UPLOAD_DIR=/tmp/aarogyakosha/uploads

LOG_LEVEL=INFO

# ─── FRONTEND ──────────────────────────────────────────
# aarogyakosha/frontend/.env.local

VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=AarogyaKosha
VITE_DEBUG=true
